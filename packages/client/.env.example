VITE_API_URL=http://localhost:14702
VITE_WS_URL=ws://localhost:14703
VITE_MEDIA_URL=http://localhost:14704
VITE_PROXY_URL=http://localhost:14705
VITE_GIFBOX_URL=http://localhost:14706

# Giphy API key (if set, GIF picker uses Giphy instead of gifbox)
VITE_GIPHY_API_KEY=

# dev-only overrides (only applied when import.meta.env.DEV is true)
# VITE_DEV_API_URL=
# VITE_DEV_WS_URL=
# VITE_DEV_MEDIA_URL=
# VITE_DEV_PROXY_URL=

# specify hCaptcha sitekey
VITE_HCAPTCHA_SITEKEY=

# specify Sentry DSN
VITE_SENTRY_DSN=
VITE_SENTRY_TUNNEL=

# configs
VITE_CFG_ENABLE_VIDEO=
